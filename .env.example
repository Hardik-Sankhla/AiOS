# AIOS Environment Configuration
# Copy this file to .env and fill in your API keys

# ==================== TIER 1 PROVIDERS (RECOMMENDED) ====================

# Groq API Key - Fast free inference
# Get at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API Key - Free quota with strong reasoning
# Get at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxx

# OpenRouter API Key - Huge model catalog
# Get at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx

# ==================== TIER 1 PROVIDERS (OPTIONAL) ====================

# Together AI API Key - Open source models
# Get at: https://api.together.xyz
TOGETHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Token - For GitHub Models (optional)
# Get at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== TIER 2 PROVIDERS (OPTIONAL) ====================

# Cerebras API Key - Fast inference
# Get at: https://www.cerebras.ai
CEREBRAS_API_KEY=csk_xxxxxxxxxxxxxxxxxxxxxx

# SambaNova API Key - Enterprise performance
# Get at: https://www.sambanova.ai
SAMBANOVA_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxx

# ==================== LOCAL ENDPOINTS ====================

# Ollama - Run local models
# Set if running: ollama serve
# Default: http://localhost:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# LM Studio - Desktop LLM interface
# Set if running LM Studio
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio

# vLLM - High-throughput local serving
# Set if running vLLM server
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=vllm

# FreeLLMAPI - Multi-provider aggregator
# See: https://github.com/tashfeenahmed/freellmapi
FREELLMAPI_BASE_URL=http://localhost:8001/v1
FREELLMAPI_API_KEY=freellmapi

# ==================== AIOS CONFIGURATION ====================

# Default LLM model
DEFAULT_LLM_MODEL=auto

# Debug mode
DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== WEBUI CONFIGURATION ====================

# FastAPI host and port
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8000
WEBUI_SSL_CERTFILE=
WEBUI_SSL_KEYFILE=

# Session database URL (optional, defaults to SQLite)
DATABASE_URL=sqlite:///./aios.db

# ==================== TELEGRAM BOT ====================

# Telegram Bot Token
# Get at: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ==================== DEPLOYMENT ====================

# Environment: development, staging, production
ENVIRONMENT=development

# Secret key for sessions (generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-secret-key-here

